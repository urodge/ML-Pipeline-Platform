# Copy this file to .env and fill in your values
# Never commit .env to Git — it's in .gitignore

# ── NewsAPI ──────────────────────────────────────────────────────────────────
# Free key at https://newsapi.org/register (100 requests/day on free tier)
NEWS_API_KEY=your_newsapi_key_here
NEWS_COUNTRY=in
NEWS_PAGESIZE=100

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://airflow:airflow@localhost:5432/pipeline

# ── GCP Cloud Storage ────────────────────────────────────────────────────────
# Path to your GCP service account JSON key
# Download from: console.cloud.google.com → IAM → Service Accounts → Keys
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/gcp-key.json
GCS_BUCKET=yourname-ml-pipeline-raw
GCP_PROJECT=your-gcp-project-id

# ── Model ────────────────────────────────────────────────────────────────────
MODEL_PATH=models/sentiment_model.pkl
MODEL_VERSION=1.0.0

# ── Slack Alerts (optional) ───────────────────────────────────────────────────
# Create an incoming webhook at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ

# ── Drift detection ───────────────────────────────────────────────────────────
DRIFT_THRESHOLD=0.05
